SUPER_ADMIN_PASSWORD="change-this-password"
SUPER_ADMIN_OTP="123456"
SUPER_ADMIN_OTP_EXPIRY="10m"

MONITOR_USERNAME="monitor"
MONITOR_PASSWORD="monitor-password"


FRONTEND_APP_URL="https://malamal.com.bd"
BACKEND_PUBLIC_URL="https://api.malamal.com.bd"


REDIS_URL="redis://localhost:6379"
REDIS_RATE_LIMIT_PREFIX="malamal:rate-limit"

RATE_LIMIT_GLOBAL_WINDOW_MS="900000"
RATE_LIMIT_GLOBAL_MAX="200"
RATE_LIMIT_PUBLIC_WINDOW_MS="60000"
RATE_LIMIT_PUBLIC_MAX="180"
RATE_LIMIT_AUTH_WINDOW_MS="60000"
RATE_LIMIT_AUTH_MAX="8"
RATE_LIMIT_ACTION_WINDOW_MS="60000"
RATE_LIMIT_ACTION_MAX="30"
RATE_LIMIT_ADMIN_WINDOW_MS="60000"
RATE_LIMIT_ADMIN_MAX="60"
RATE_LIMIT_PAYMENT_WINDOW_MS="60000"
RATE_LIMIT_PAYMENT_MAX="12"
RATE_LIMIT_BOT_PENALTY_FLOOR="2"
REQUEST_DEDUP_WINDOW_MS="5000"



PORTPOS_APP_KEY="your-portpos-app-key"
PORTPOS_SECRET_KEY="your-portpos-secret-key"
PORTPOS_BASE_URL="https://api.portpos.com/payment/v2"
PORTPOS_PAYMENT_URL="https://api.portpos.com/payment/v2/invoice"
