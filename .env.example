NODE_ENV="development"
CONTACT_US_EMAIL="sales@malamal.com.bd"

PORT="5003"

ALLOWED_ORIGINS="https://malamal.com.bd,https://www.malamal.com.bd"

DB_URL="mongodb://127.0.0.1:27017/malamal"


PREFFERED_WEBSITE_NAME="Malamal"
CLOUDINARY_FOLDER_NAME="malamal/images"
EMAIL_COLOR="#111111"

BCRYPT_SALT_ROUNDS="10"
OTP_EXPIRY_MINUTES="10"


JWT_ACCESS_SECRET="replace-with-access-secret"
JWT_ACCESS_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="replace-with-refresh-secret"
JWT_REFRESH_EXPIRES_IN="30d"
JWT_OTP_SECRET="replace-with-otp-secret"
JWT_OTP_SECRET_EXPIRES_IN="10m"



CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

EMAIL_FOR_NODEMAILER="your-email@example.com"
PASSWORD_FOR_NODEMAILER="your-email-password"


SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_PHONE="01234567890"
