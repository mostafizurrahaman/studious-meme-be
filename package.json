{
  "name": "malamal_apis",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "server.ts",
  "author": {
    "name": "Mostafizur Rahaman",
    "email": "mostafizurrahaman0401@gmail.com",
    "url": "https://mostafizur-rahaman-portfolio.web.app"
  },
  "description": "Malamal: A high-performance, mobile-first e-commerce and price comparison engine. Built with the MERN stack and Next.js, it enables users to discover real-time deals and compare product prices across various retailers to maximize savings.",
  "keywords": [
    "malamal",
    "ecommerce-platform",
    "price-comparison",
    "real-time-deals",
    "nextjs",
    "typescript",
    "expressjs",
    "mongodb",
    "mongoose",
    "fullstack-web-development",
    "smart-shopping",
    "backend-architecture"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "ts-node-dev --respawn --transpile-only --poll ./src/server.ts",
    "build": "tsc",
    "start": "node ./dist/server.js",
    "generate": "node generate",
    "create-module": "npx ts-node ./src/scripts/createModule.ts",
    "deploy": "pnpm build && vercel && vercel --prod",
    "format": "prettier . --write",
    "dev2": "cross-env NODE_ENV=development tsx watch ./src/server.ts",
    "build2": "tsc && tsc-alias",
    "prod:dev": "cross-env NODE_ENV=production tsx watch ./src/server.ts",
    "prod": "cross-env NODE_ENV=production node ./dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules",
    "prettier": "prettier --ignore-path .gitignore --write \"./src/**/*.+(js|ts|json)\"",
    "prettier:fix": "npx prettier --write src"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "colors": "^1.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "multer": "2.1.1",
    "nodemailer": "^8.0.7",
    "os-utils": "^0.0.14",
    "otp-generator": "^4.0.1",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/os-utils": "^0.0.4",
    "@types/otp-generator": "^4.0.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "morgan": "^1.10.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}